,\n      movements: [], orders: [],\n      profile: (cached && cached.profile) || { name: 'Happy TCG', tagline: '', about: '', address: '', phone: '', whatsapp: '', hours: '', facebook: '', tiktok: '', instagram: '', rateLAK: 605, rateUSD: 36 },\n      cart\n    };\n    this._toastTimer = null;\n    this._profTimer = null;\n  }\n\n  componentDidMount() {\n    try { document.documentElement.lang = 'en'; } catch (e) {}\n    // Preload likely-LCP images from the cached catalog so they start downloading before render\n    try {\n      const st = this.state;\n      const urls = [st.profile.banner, st.profile.background].concat(st.products.slice(0, 4).map(p => p.images && p.images[0]));\n      urls.filter(Boolean).forEach(u => {\n        const l = document.createElement('link');\n        l.rel = 'preload'; l.as = 'image'; l.href = u; l.fetchPriority = 'high';\n        document.head.appendChild(l);\n      });\n    } catch (e) {}\n    this.loadCatalog(); // fires immediately over raw REST — supabase-js is only loaded on demand\n  }\n\n  // Lazy-load supabase-js only when a write/auth operation needs it — shoppers browsing never download it\n  ensureSb() {\n    if (this.sb) return Promise.resolve(this.sb);\n    if (!this._sbLoad) {\n      this._sbLoad = new Promise((resolve, reject) => {\n        const done = () => { this.sb = window.supabase.createClient(this.SB_URL, this.SB_KEY); resolve(this.sb); };\n        if (window.supabase) { done(); return; }\n        const sc = document.createElement('script');\n        sc.src = 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js';\n        sc.onload = done;\n        sc.onerror = () => { this._sbLoad = null; reject(new Error('connection problem — try again')); };\n        document.head.appendChild(sc);\n      });\n    }\n    return this._sbLoad;\n  }\n\n  // Direct PostgREST fetch — skips the supabase-js client so first paint isn't blocked on the CDN script\n  rest(q) {\n    return fetch(this.SB_URL + '/rest/v1/' + q, { headers: { apikey: this.SB_KEY, Authorization: 'Bearer ' + this.SB_KEY } })\n      .then(r => r.json().then(data => r.ok ? { data, error: null } : { data: null, error: (data && data.message) ? data : { message: 'HTTP ' + r.status } }))\n      .catch(e => ({ data: null, error: { message: e.message || 'network error' } }));\n  }\n\n  pubUrl(bucket, path) {\n    return path ? this.SB_URL + '/storage/v1/object/public/' + bucket + '/' + path : null;\n  }\n\n  async loadCatalog() {\n    try {\n      // Use the fetches started by the inline <head> script if they're available (first load only)\n      var pre = window.__catalogFetch; window.__catalogFetch = null;\n      const [cats, tags, prods, prof] = await (pre || Promise.all([\n        this.rest('categories?select=*&order=created_at'),\n        this.rest('tags?select=*&order=created_at'),\n        this.rest('products?select=*,product_images(storage_path,sort_order),product_tags(tags(name))&order=created_at'),\n        this.rest('store_profile?select=*&id=eq.1')\n      ]));\n      const err = cats.error || tags.error || prods.error || prof.error;\n      if (err) throw err;\n      const imgsByP = {};\n      const tagsByP = {};\n      (prods.data || []).forEach(r => {\n        imgsByP[r.id] = (r.product_images || []).slice().sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0)).map(x => ({ path: x.storage_path, url: this.pubUrl('product-photos', x.storage_path) }));\n        tagsByP[r.id] = (r.product_tags || []).map(x => x.tags && x.tags.name).filter(Boolean);\n      });\n      const products = (prods.data || []).map(r => ({\n        id: r.id, name: r.name, desc: r.description || '', category: r.category_id,\n        price: Number(r.price_thb) || 0,\n        priceLAK: r.price_lak != null ? Number(r.price_lak) : 0,\n        priceUSD: r.price_usd != null ? Number(r.price_usd) : 0,\n        cost: Number(r.cost_thb) || 0, uom: r.uom, stock: r.stock,\n        color: r.tile_color || '#FF5C39',\n        images