fileChange: (e) => {\n        const field = e.target.name, value = e.target.value;\n        this.setState({ profile: { ...s.profile, [field]: value } });\n        this.pushProfile({ [field]: value });\n      },\n\n      hasBanner: !!s.profile.banner,\n      noBanner: !s.profile.banner,\n      bannerEl: this.photoEl(s.profile.banner, null, true),\n      onBannerPick: (e) => this.pickProfileImage(e, 'banner', 'banner_path', 1600, 'Banner'),\n      removeBanner: () => this.removeProfileImage('banner', 'banner_path', 'Banner'),\n      hasLogo: !!s.profile.logo,\n      noLogo: !s.profile.logo,\n      logoEl: this.photoEl(s.profile.logo, 'Store logo', true),\n      onLogoPick: (e) => this.pickProfileImage(e, 'logo', 'logo_path', 256, 'Logo', true),\n      removeLogo: () => this.removeProfileImage('logo', 'logo_path', 'Logo'),\n      hasBg: !!s.profile.background,\n      noBg: !s.profile.background,\n      bgEl: s.profile.background ? React.createElement('div', {\n        'aria-hidden': 'true',\n        style: { position: 'fixed', inset: 0, zIndex: -1, backgroundImage: 'url(\"' + s.profile.background + '\")', backgroundSize: 'cover', backgroundPosition: 'center' }\n      }) : null,\n      bgPreviewEl: this.photoEl(s.profile.background),\n      onBgPick: (e) => this.pickProfileImage(e, 'background', 'background_path', 1920, 'Page background'),\n      removeBg: () => this.removeProfileImage('background', 'background_path', 'Page background'),\n\n      modalOpen: s.modalOpen,\n      modalTitle: s.form.id ? 'Edit product' : 'Add product',\n      formIsEdit: !!s.form.id,\n      form: s.form,\n      colorOptions,\n      formTagChips,\n      formPhotoRows,\n      formPhotoCount: s.form.images.length,\n      onFormChange: (e) => this.setState({ form: { ...s.form, [e.target.name]: e.target.value } }),\n      onPhotoPick: (e) => this.onPhotoPick(e),\n      autoLAK: s.form.price ? 'auto: ' + Math.round(Number(s.form.price) * this.rateLAK()).toLocaleString('en-US') : 'auto from THB',\n      autoUSD: s.form.price ? 'auto: ' + (Number(s.form.price) / this.rateUSD()).toFixed(2) : 'auto from THB',\n      openAddProduct: () => this.setState({ modalOpen: true, form: { ...this.blankForm(), category: s.categories[0] ? s.categories[0].id : '' } }),\n      closeModal: () => this.setState({ modalOpen: false }),\n      saveProduct: () => this.saveProduct(),\n      saveProductLabel: s.saving ? 'Saving…' : 'Save product',\n      deleteProduct: () => this.deleteProduct(),\n\n      toast: s.toast,\n      hasToast: !!s.toast\n    };\n  }\n}\n<\u002Fscript>\n\n\n<\u002Fbody><\u002Fhtml>"
