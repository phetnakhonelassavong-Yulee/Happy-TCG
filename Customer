m('happy-tcg-catalog-v1', JSON.stringify(cached));\n      } catch (e) {}\n    } catch (e) {}\n  }\n\n  async loadOwnerData() {\n    this.ensureUoms();\n    try {\n      const [movs, ords] = await Promise.all([\n        this.sb.from('stock_movements').select('*').order('created_at', { ascending: false }).limit(300),\n        this.sb.from('orders').select('*, order_items(*)').order('created_at', { ascending: false }).limit(200)\n      ]);\n      if (movs.error || ords.error) throw (movs.error || ords.error);\n      const movements = (movs.data || []).map(r => ({\n        id: r.id, date: Date.parse(r.created_at), productId: r.product_id, type: r.type, qty: r.qty, note: r.note || ''\n      }));\n      const orders = (ords.data || []).map(r => ({\n        uuid: r.id, id: r.order_no, date: Date.parse(r.created_at),\n        total: Number(r.total_thb) || 0,\n        units: (r.order_items || []).reduce((a, it) => a + it.qty, 0),\n        customer: r.customer_name, phone: r.customer_phone || '',\n        address: r.delivery_address || '', shipping: r.shipping_details || '',\n        status: r.status,\n        items: (r.order_items || []).map(it => ({ name: it.product_name, qty: it.qty, uom: it.uom }))\n      }));\n      this.setState({ movements, orders });\n    } catch (e) {\n      this.toast('Could not load orders/stock: ' + (e.message || e));\n    }\n  }\n\n  blankForm() {\n    return { id: null, name: '', category: '', price: '', priceLAK: '', priceUSD: '', cost: '', uom: 'pcs', stock: '', color: '#FF5C39', desc: '', images: [], tags: [] };\n  }\n\n  dataUrlToBlob(dataUrl) {\n    const [head, b64] = dataUrl.split(',');\n    const mime = head.match(/data:(.*?);/)[1];\n    const bin = atob(b64);\n    const arr = new Uint8Array(bin.length);\n    for (let i = 0; i < bin.length; i++) arr[i] = bin.charCodeAt(i);\n    return new Blob([arr], { type: mime });\n  }\n\n  resizeFile(file, max, usePng) {\n    return new Promise((resolve) => {\n      const reader = new FileReader();\n      reader.onload = () => {\n        const img = new Image();\n        img.onload = () => {\n          const scale = Math.min(1, max / Math.max(img.width, img.height));\n          const canvas = document.createElement('canvas');\n          canvas.width = Math.round(img.width * scale);\n          canvas.height = Math.round(img.height * scale);\n          canvas.getContext('2d').drawImage(img, 0, 0, canvas.width, canvas.height);\n          resolve(usePng ? canvas.toDataURL('image/png') : canvas.toDataURL('image/jpeg', 0.82));\n        };\n        img.src = reader.result;\n      };\n      reader.readAsDataURL(file);\n    });\n  }\n\n  onPhotoPick(e) {\n    const files = Array.from(e.target.files || []);\n    e.target.value = '';\n    files.forEach(async (file) => {\n      const dataUrl = await this.resizeFile(file, 640);\n      this.setState(st => ({ form: { ...st.form, images: st.form.images.concat([{ src: dataUrl, path: null }]) } }));\n    });\n    if (files.length) this.toast(files.length + ' photo(s) added — remember to save');\n  }\n\n  async pickProfileImage(e, field, col, max, label, usePng) {\n    const file = e.target.files && e.target.files[0];\n    if (!file) return;\n    e.target.value = '';\n    try {\n      const dataUrl = await this.resizeFile(file, max, usePng);\n      const blob = this.dataUrlToBlob(dataUrl);\n      const path = field + '_' + Date.now() + (usePng ? '.png' : '.jpg');\n      const up = await this.sb.storage.from('branding').upload(path, blob, { contentType: blob.type });\n      if (up.error) throw up.error;\n      const upd = await this.sb.from('store_profile').update({ [col]: path }).eq('id', 1);\n      if (upd.error) throw upd.error;\n      this.setState({ profile: { ...this.state.profile, [field]: this.pubUrl('branding', path) } });\n      this.toast(label + ' updated!');\n    } catch (err) {\n      this.toast('Upload failed: ' + (err.message || err));\n    }\n  }\n\n  async removeProfileImage(field, col, label) {\n    try {\n      const upd = await this.sb.from('store_profile').update({ [col]: null }).eq('id', 1);\n      if (upd.error) throw upd.error;\n      const p = { ...this.state.profile };\n      delete p[field];\n      this.setState({ profile: p });\n      this.toast(label + ' removed');\n    } catch (err) {\n      this.toast('Failed: ' + (err.message || err));\n    }\n  }\n\n  persistCart() {\n    try { localStorage.setItem('happy-tcg-cart-v2', JSON.stringify(this.state.cart)); } catch (e) {}\n  }\n\n  toast(msg) {\n    clearTimeout(this._toastTimer);\n    this.setState({ toast: msg });\n    this._toastTimer = setTimeout(() => this.setState({ toast: '' }), 2800);\n  }\n\n  rateLAK() { return this.state.profile.rateLAK || 605; }\n  rateUSD() { return this.state.profile.rateUSD || 36; }\n\n  fmt(thb) {\n    const c = this.state.cur;\n    if (c === 'USD') return '$' + (thb / this.rateUSD()).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n    if (c === 'LAK') return '₭' + Math.round(thb * this.rateLAK()).toLocaleString('en-US');\n    return '฿' + Math.round(thb).toLocaleString('en-US');\n  }\n\n  priceFor(p) {\n    const c = this.state.cur;\n    if (c === 'USD') return p.priceUSD > 0 ? p.priceUSD : Math.round(p.price / this.rateUSD() * 100) / 100;\n    if (c === 'LAK') return p.priceLAK > 0 ? p.priceLAK : Math.round(p.price * this.rateLAK());\n    return p.price;\n  }\n\n  fmtCur(v) {\n    const c = this.state.cur;\n    if (c === 'USD') return '$' + v.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n    if (c === 'LAK') return '₭' + Math.round(v).toLocaleString('en-US');\n    return '฿' + v.toLocaleString('en-US');\n  }\n\n  glyph(name) {\n    const parts = name.split(' ').filter(w => /[A-Za-z0-9]/.test(w[0]));\n    return (parts[0] ? parts[0][0] : '?') + (parts[1] ? parts[1][0] : '');\n  }\n\n  tileBg(color) {\n    return 'repeating-linear-gradient(45deg,' + color + '1f 0 12px,' + color + '3d 12px 24px)';\n  }\n\n  photoEl(image, label, eager) {\n    if (!image) return null;\n    return React.createElement('img', {\n      fetchPriority: eager ? 'high' : undefined,\n      src: image,\n      alt: label || '',\n      'aria-hidden': label ? undefined : 'true',\n      loading: eager ? 'eager' : 'lazy',\n      decoding: 'async',\n      draggable: false,\n      style: { position: 'absolute', inset: 0, width: '100%', height: '100%', objectFit: 'cover' }\n    });\n  }\n\n  catName(id) {\n    const c = this.state.categories.find(c => c.id === id);\n    return c ? c.name : '—';\n  }\n\n  cartQty(pid) {\n    const ci = this.state.cart.find(c => c.productId === pid);\n    return ci ? ci.qty : 0;\n  }\n\n  addToCart(p, qty) {\n    qty = qty || 1;\n    const inCart = this.cartQty(p.id);\n    if (p.stock <= 0) { this.toast('Sold out — check back soon!'); return; }\n    if (inCart + qty > p.stock) { this.toast('Only ' + p.stock + ' ' + p.uom + ' in stock (' + inCart + ' already in cart)'); return; }\n    const cart = this.state.cart.slice();\n    const ci = cart.find(c => c.productId === p.id);\n    if (ci) cart[cart.indexOf(ci)] = { ...ci, qty: ci.qty + qty };\n    else cart.push({ productId: p.id, qty });\n    this.setState({ cart }, () => this.persistCart());\n    this.toast('Added ' + qty + ' × \"' + p.name + '\" to cart');\n  }\n\n  productVM(p, eager) {\n    const threshold = this.props.lowStockThreshold ?? 3;\n    const inStock = p.stock > 0;\n    const low = inStock && p.stock <= threshold;\n    const images = p.images || [];\n    return {\n      id: p.id, name: p.name, uom: p.uom, stock: p.stock, color: p.color,\n      hasImg: images.length > 0, noImg: images.length === 0,\n      multiImg: images.length > 1, imgCount: images.length,\n      photoEl: this.photoEl(images[0], images.length ? p.name : null, eager),\n      tagChips: (p.tags || []).map(t => ({ name: t })),\n      desc: p.desc || '', glyph: this.glyph(p.name), tileBg: this.tileBg(p.color),\n      catName: this.catName(p.category),\n      priceStr: this.fmtCur(this.priceFor(p)),\n      stockLabel: !inStock ? 'Sold out' : (low ? 'Only ' + p.stock + ' left!' : 'In stock'),\n      stockColor: !inStock ? '#D63E1E' : (low ? '#E08700' : '#4CB944'),\n      inStock,\n      btnLabel: inStock ? '+ Add' : 'Sold out',\n      btnLabelBig: inStock ? 'Add to cart' : 'Sold out',\n      btnBg: inStock ? '#FF5C39' : '#E7DCC8',\n      btnFg: inStock ? '#fff' : '#6B5E85',\n      open: () => this.setState({ screen: 'product', selId: p.id, galleryIdx: 0, detailQty: 1, filtersOpen: false }),\n      openKey: (e) => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); this.setState({ screen: 'product', selId: p.id, galleryIdx: 0, detailQty: 1, filtersOpen: false }); } },\n      addToCart: () => this.addToCart(p, 1)\n    };\n  }\n\n  moveVM(m) {\n    const p = this.state.products.find(x => x.id === m.productId);\n    const isIn = m.type === 'in';\n    const labels = { 'in': 'Stock in', 'out': 'Stock out', 'sale': 'Sale', 'adjust': 'Adjustment' };\n    return {\n      qtyStr: (isIn ? '+' : '−') + m.qty,\n      badgeBg: isIn ? '#DFF5E1' : '#FFE3D6',\n      badgeFg: isIn ? '#2E7D32' : '#D63E1E',\n      name: p ? p.name : '(deleted product)',\n      typeLabel: labels[m.type] || m.type,\n      when: new Date(m.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' }),\n      note: m.note || '—'\n    };\n  }\n\n  orderVM(o, forOwner) {\n    const statusMeta = {\n      'new': { label: 'New', bg: '#FFC93C', fg: '#2B2140' },\n      'preparing': { label: 'Preparing', bg: '#7B61FF', fg: '#fff' },\n      'ready': { label: 'Ready for pickup', bg: '#00A896', fg: '#fff' },\n      'completed': { label: 'Completed', bg: '#4CB944', fg: '#fff' }\n    };\n    const meta = statusMeta[o.status] || statusMeta['new'];\n    const vm = {\n      id: o.id,\n      when: new Date(o.date).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' }),\n      customer: o.customer,\n      phone: o.phone || '—',\n      units: o.units,\n      totalStr: this.fmt(o.total),\n      itemsStr: (o.items || []).map(it => it.qty + '× ' + it.name).join(', ') || '—',\n      shippingStr: [o.address, o.shipping].filter(Boolean).join(' · ') || 'No address / shipping details',\n      status: o.status,\n      statusLabel: meta.label, statusBg: meta.bg, statusFg: meta.fg\n    };\n    if (forOwner) {\n      vm.onStatus = async (e) => {\n        const status = e.target.value;\n        const upd = await this.sb.from('orders').update({ status }).eq('id', o.uuid);\n        if (upd.error) { this.toast('Failed: ' + upd.error.message); return; }\n        this.setState({ orders: this.state.orders.map(x => x.uuid === o.uuid ? { ...x, status } : x) });\n        this.toast(o.id + ' → ' + (statusMeta[status] || statusMeta['new']).label);\n      };\n    }\n    return vm;\n  }\n\n  async submitStock() {\n    const f = this.state.stockForm;\n    const pid = f.productId || (this.state.products[0] && this.state.products[0].id);\n    const p = this.state.products.find(x => x.id === pid);\n    const qty = Math.floor(Number(f.qty));\n    if (!p) { this.toast('Pick a product first'); return; }\n    if (!qty || qty <= 0) { this.toast('Enter a quantity greater than 0'); return; }\n    if (f.type === 'out' && qty > p.stock) { this.toast('Not enough stock — only ' + p.stock + ' ' + p.uom); return; }\n    const newStock = f.type === 'in' ? p.stock + qty : p.stock - qty;\n    try {\n      const ins = await this.sb.from('stock_movements').insert({ product_id: p.id, type: f.type, qty, note: f.note || 'Manual ' + f.type });\n      if (ins.error) throw ins.error;\n      const upd = await this.sb.from('products').update({ stock: newStock, updated_at: new Date().toISOString() }).eq('id', p.id);\n      if (upd.error) throw upd.error;\n      this.setState({\n        products: this.state.products.map(x => x.id === p.id ? { ...x, stock: newStock } : x),\n        movements: [{ id: 'tmp' + Date.now(), date: Date.now(), productId: p.id, type: f.type, qty, note: f.note || 'Manual ' + f.type }].concat(this.state.movements),\n        stockForm: { ...f, qty: '', note: '' }\n      });\n      this.toast('Saved: ' + (f.type === 'in' ? '+' : '−') + qty + ' ' + p.uom + ' of ' + p.name);\n    } catch (e) {\n      this.toast('Failed to save: ' + (e.message || e));\n    }\n  }\n\n  async saveProduct() {\n    const f = this.state.form;\n    if (this.state.saving) return;\n    if (!f.name.trim()) { this.toast('Give the product a name'); return; }\n    if (!f.category) { this.toast('Pick a category'); return; }\n    this.setState({ saving: true });\n    try {\n      const price = Number(f.price) || 0;\n      const priceLAK = Number(f.priceLAK) || 0;\n      const priceUSD = Number(f.priceUSD) || 0;\n      const cost = Number(f.cost) || 0;\n      const stock = Math.max(0, Math.floor(Number(f.stock) || 0));\n      const row = {\n        name: f.name.trim(), description: f.desc || '', category_id: f.category,\n        uom: f.uom, price_thb: price,\n        price_lak: priceLAK > 0 ? priceLAK : null,\n        price_usd: priceUSD > 0 ? priceUSD : null,\n        cost_thb: cost, stock, tile_color: f.color,\n        updated_at: new Date().toISOString()\n      };\n      let pid = f.id;\n      if (pid) {\n        const old = this.state.products.find(p => p.id === pid);\n        const upd = await this.sb.from('products').update(row).eq('id', pid);\n        if (upd.error) throw upd.error;\n        if (old && old.stock !== stock) {\n          await this.sb.from('stock_movements').insert({ product_id: pid, type: 'adjust', qty: Math.abs(stock - old.stock), note: 'Adjustment via edit (' + (stock > old.stock ? '+' : '−') + Math.abs(stock - old.stock) + ')' });\n        }\n      } else {\n        const ins = await this.sb.from('products').insert(row).select().single();\n        if (ins.error) throw ins.error;\n        pid = ins.data.id;\n        if (stock > 0) {\n          await this.sb.from('stock_movements').insert({ product_id: pid, type: 'in', qty: stock, note: 'Opening stock' });\n        }\n      }\n      // tags: replace set\n      await this.sb.from('product_tags').delete().eq('product_id', pid);\n      const tagIds = f.tags.map(name => {\n        const t = this.state.tags.find(x => x.name === name);\n        return t ? t.id : null;\n      }).filter(Boolean);\n      if (tagIds.length) {\n        const insT = await this.sb.from('product_tags').insert(tagIds.map(tag_id => ({ product_id: pid, tag_id })));\n        if (insT.error) throw insT.error;\n      }\n      // images: upload new ones, then replace rows\n      const finalImgs = [];\n      for (let i = 0; i < f.images.length; i++) {\n        const im = f.images[i];\n        if (im.path) { finalImgs.push(im.path); continue; }\n        const blob = this.dataUrlToBlob(im.src);\n        const path = pid + '/' + Date.now() + '_' + i + '.jpg';\n        const up = await this.sb.storage.from('product-photos').upload(path, blob, { contentType: 'image/jpeg' });\n        if (up.error) throw up.error;\n        finalImgs.push(path);\n      }\n      await this.sb.from('product_images').delete().eq('product_id', pid);\n      if (finalImgs.length) {\n        const insI = await this.sb.from('product_images').insert(finalImgs.map((storage_path, i) => ({ product_id: pid, storage_path, sort_order: i })));\n        if (insI.error) throw insI.error;\n      }\n      this.setState({ saving: false, modalOpen: false, form: this.blankForm() });\n      this.toast((f.id ? 'Updated' : 'Added') + ' \"' + f.name.trim() + '\"');\n      this.loadCatalog();\n      if (this.state.ownerAuthed) this.loadOwnerData();\n    } catch (e) {\n      this.setState({ saving: false });\n      this.toast('Save failed: ' + (e.message || e));\n    }\n  }\n\n  async deleteProduct() {\n    const f = this.state.form;\n    if (!f.id) return;\n    try {\n      const del = await this.sb.from('products').delete().eq('id', f.id);\n      if (del.error) throw del.error;\n      const cart = this.state.cart.filter(c => c.productId !== f.id);\n      this.setState({ modalOpen: false, form: this.blankForm(), cart }, () => this.persistCart());\n      this.toast('Deleted \"' + f.name + '\"');\n      this.loadCatalog();\n    } catch (e) {\n      this.toast('Delete failed: ' + (e.message || e));\n    }\n  }\n\n  async placeOrder() {\n    if (this.state.placing) return;\n    const cart = this.state.cart;\n    const co = this.state.checkout;\n    if (!cart.length) { this.toast('Cart is empty'); return; }\n    if (!co.name.trim()) { this.toast('Please enter your name'); return; }\n    this.setState({ placing: true });\n    try {\n      await this.ensureSb();\n      const res = await this.sb.rpc('place_order', {\n        p_customer_name: co.name.trim(),\n        p_customer_phone: co.phone.trim(),\n        p_address: co.address.trim(),\n        p_shipping: co.shipping.trim(),\n        p_currency: this.state.cur,\n        p_items: cart.map(ci => ({ product_id: ci.productId, qty: ci.qty }))\n      });\n      if (res.error) throw res.error;\n      const orderNo = res.data && res.data.order_no ? res.data.order_no : 'HT-?';\n      // WhatsApp message from local data\n      const items = cart.map(ci => {\n        const p = this.state.products.find(x => x.id === ci.productId);\n        return p ? { name: p.name, qty: ci.qty, lineStr: this.fmtCur(this.priceFor(p) * ci.qty) } : null;\n      }).filter(Boolean);\n      const totalCur = cart.reduce((a, ci) => {\n        const p = this.state.products.find(x => x.id === ci.productId);\n        return a + (p ? this.priceFor(p) * ci.qty : 0);\n      }, 0);\n      const digits = (this.state.profile.whatsapp || '').replace(/[^0-9]/g, '');\n      const waLines = [\n        'New order ' + orderNo + ' — ' + this.state.profile.name,\n        'Customer: ' + co.name.trim() + (co.phone.trim() ? ' (' + co.phone.trim() + ')' : ''),\n        co.address.trim() ? 'Address: ' + co.address.trim() : '',\n        co.shipping.t