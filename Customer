rders: s.orders.length === 0,\n\n      ownerTabs,\n      tabDash: ownerUnlocked && s.tab === 'dash',\n      tabOrders: ownerUnlocked && s.tab === 'orders',\n      tabProducts: ownerUnlocked && s.tab === 'products',\n      tabStock: ownerUnlocked && s.tab === 'stock',\n      tabCats: ownerUnlocked && s.tab === 'cats',\n      tabProfile: ownerUnlocked && s.tab === 'profile',\n      statCards,\n      lowStockList, lowStockCount: lowStockList.length, noLowStock: lowStockList.length === 0,\n      recentMoves: allMoves.slice(0, 6),\n      allMoves,\n      productCount: ownerProducts.length,\n      ownerProducts,\n      ownerCatFilter: s.ownerCatFilter,\n      ownerUomFilter: s.ownerUomFilter,\n      onOwnerCatFilter: (e) => this.setState({ ownerCatFilter: e.target.value }),\n      onOwnerUomFilter: (e) => this.setState({ ownerUomFilter: e.target.value }),\n      uomOptions: Array.from(new Set(s.products.map(p => p.uom))).sort().map(u => ({ id: u, name: u })),\n\n      stockForm: { ...s.stockForm, productId: stockPid },\n      productOptions: s.products.map(p => ({ id: p.id, label: p.name + ' (' + p.stock + ' ' + p.uom + ')' })),\n      onStockChange: (e) => this.setState({ stockForm: { ...s.stockForm, productId: stockPid, [e.target.name]: e.target.value } }),\n      setStockIn: () => this.setState({ stockForm: { ...s.stockForm, productId: stockPid, type: 'in' } }),\n      setStockOut: () => this.setState({ stockForm: { ...s.stockForm, productId: stockPid, type: 'out' } }),\n      inBtnBg: s.stockForm.type === 'in' ? '#00A896' : '#fff', inBtnFg: s.stockForm.type === 'in' ? '#fff' : '#2B2140',\n      outBtnBg: s.stockForm.type === 'out' ? '#D63E1E' : '#fff', outBtnFg: s.stockForm.type === 'out' ? '#fff' : '#2B2140',\n      submitStock: () => this.submitStock(),\n\n      newCat: s.newCat,\n      onNewCat: (e) => this.setState({ newCat: e.target.value }),\n      addCategory: async () => {\n        const name = s.newCat.trim();\n        if (!name) { this.toast('Type a category